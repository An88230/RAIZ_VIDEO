{
  "name": "raiz-video",
  "version": "0.1.0",
  "private": true,
  "description": "RAIZ Video Factory phase 1 workspace.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:orchestrator": "npm --workspace @raiz/orchestrator run dev",
    "raiz:local-pipeline": "bash scripts/run-local-pipeline.sh",
    "raiz:render-arabic": "node scripts/render-arabic-local.mjs",
    "raiz:fetch-broll": "node scripts/fetch-pexels-broll.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
