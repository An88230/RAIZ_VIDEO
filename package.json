{
  "name": "raiz-video",
  "version": "0.1.0",
  "private": true,
  "description": "RAIZ Video Factory phase 1 workspace.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
