{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nabil88.art/schemas/creative_os_command.schema.json",
  "title": "Creative OS Local Agent Command",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "command_id",
    "source",
    "requested_action",
    "natural_language_command",
    "project_context",
    "payload",
    "safety",
    "created_at"
  ],
  "properties": {
    "command_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "source": {
      "type": "string",
      "enum": ["creative_os_ui", "voice_input", "typed_input", "local_agent_test"]
    },
    "requested_action": {
      "type": "string",
      "enum": [
        "create_creative_brief",
        "convert_brief_to_job",
        "generate_gemini_voice",
        "run_local_render",
        "inspect_job_artifacts",
        "create_review_package",
        "git_status",
        "git_log",
        "open_project_folder",
        "open_render_output",
        "show_mode_wake",
        "get_system_status",
        "get_git_status",
        "get_latest_job_status",
        "get_latest_render_status",
        "get_review_package_status",
        "get_publish_package_status",
        "get_next_recommended_action",
        "list_content_radar_modes",
        "get_content_radar_mode",
        "analyze_content_pattern",
        "generate_original_remake_ideas",
        "generate_affiliate_angles"
      ]
    },
    "natural_language_command": {
      "type": "string",
      "minLength": 1
    },
    "project_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace", "project"],
      "properties": {
        "workspace": {
          "type": "string",
          "const": "RAIZ_VIDEO"
        },
        "project": {
          "type": "string",
          "minLength": 1
        },
        "job_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "language": {
          "type": "string",
          "enum": ["ar", "en"]
        },
        "direction": {
          "type": "string",
          "enum": ["rtl", "ltr"]
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "project": {
          "type": "string",
          "minLength": 1
        },
        "concept": {
          "type": "string",
          "minLength": 1
        },
        "template_id": {
          "type": "string",
          "minLength": 1
        },
        "voice_provider": {
          "type": "string",
          "enum": ["gemini_tts", "local_file", "none"]
        },
        "output": {
          "type": "string",
          "enum": ["local_mp4", "local_artifacts"]
        },
        "publish": {
          "type": "boolean"
        },
        "duration_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600
        },
        "creative_brief": {
          "type": "object"
        },
        "job_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "question_type": {
          "type": "string",
          "enum": [
            "system_status",
            "git_status",
            "latest_job_status",
            "latest_render_status",
            "review_package_status",
            "publish_status",
            "next_recommended_action"
          ]
        },
        "include_git": {
          "type": "boolean"
        },
        "include_latest_job": {
          "type": "boolean"
        },
        "include_latest_render": {
          "type": "boolean"
        },
        "include_review_status": {
          "type": "boolean"
        },
        "include_publish_status": {
          "type": "boolean"
        },
        "required_answer_when_missing": {
          "type": "string",
          "minLength": 1
        },
        "required_answer_when_publish_package_exists": {
          "type": "string",
          "minLength": 1
        },
        "must_not_publish": {
          "type": "boolean",
          "const": true
        },
        "content_radar_mode_id": {
          "type": "string",
          "enum": ["tech_discovery", "home_maintenance", "daily_life"]
        },
        "content_reference": {
          "type": "object"
        },
        "pattern_report_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "analysis_goal": {
          "type": "string",
          "enum": [
            "pattern_report",
            "original_remake_ideas",
            "affiliate_angles",
            "mode_lookup"
          ]
        },
        "must_not_download": {
          "type": "boolean",
          "const": true
        },
        "must_not_scrape": {
          "type": "boolean",
          "const": true
        },
        "must_not_repost": {
          "type": "boolean",
          "const": true
        },
        "copy_patterns_not_videos": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requires_confirmation",
        "allow_arbitrary_shell",
        "allowed_paths",
        "secrets_in_payload"
      ],
      "properties": {
        "requires_confirmation": {
          "type": "boolean"
        },
        "allow_arbitrary_shell": {
          "type": "boolean",
          "const": false
        },
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "secrets_in_payload": {
          "type": "boolean",
          "const": false
        },
        "audit_log_required": {
          "type": "boolean",
          "const": true
        },
        "network_allowed": {
          "type": "boolean"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
