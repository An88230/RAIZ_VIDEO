      "name": "Golden Time Gate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        96
      ],
      "parameters": {
        "jsCode": "const allowed = new Set(['11:00','18:30']);\nconst parts = new Intl.DateTimeFormat('en-GB', {\n  timeZone: 'Asia/Riyadh',\n  hour: '2-digit',\n  minute: '2-digit',\n  hour12: false\n}).formatToParts(new Date());\nconst hour = parts.find(p => p.type === 'hour')?.value || '00';\nconst minute = parts.find(p => p.type === 'minute')?.value || '00';\nconst current = hour + ':' + minute;\nif (!allowed.has(current)) return [];\nreturn [{ json: { golden_time_matched: true, current_riyadh_time: current, golden_publish_times: Array.from(allowed) } }];"
      }
    },
    {
      "id": "50a12cfc-2975-4bc2-8098-7bbab8816ff2",
      "name": "Read Rendered Inventory",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [
        448,
        96
      ],
      "parameters": {
        "resource": "sheet",
        "operation": "read",
        "authentication": "oAuth2",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "1feNLjbK6jfYVAz6wofPIawwcth8BTLK-cvxu30zZAvE",
          "cachedResultName": "RAIZ Video Factory Control Sheet v1"
        },
        "sheetName": {
          "__rl": true,
          "mode": "name",
          "value": "VIDEOS_MASTER",
          "cachedResultName": "VIDEOS_MASTER"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "main_status",
              "lookupValue": "RENDERED"
            }
          ]
        },
        "combineFilters": "AND",
        "options": {
          "returnAllMatches": "returnAllMatches",
          "outputFormatting": {
