{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nabil88.art/schemas/creative_brief.schema.json",
  "title": "RAIZ Creative OS Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "project",
    "objective",
    "tone",
    "platform",
    "visual_code",
    "template_intent",
    "beats"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "tone": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string",
      "enum": ["youtube_shorts", "instagram_reels", "tiktok", "local_only"]
    },
    "language": {
      "type": "string",
      "enum": ["ar", "en"],
      "default": "ar"
    },
    "direction": {
      "type": "string",
      "enum": ["rtl", "ltr"],
      "default": "rtl"
    },
    "visual_code": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "palette": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "typography": {
          "type": "string",
          "minLength": 1
        },
        "pacing": {
          "type": "string",
          "minLength": 1
        },
        "lighting": {
          "type": "string",
          "minLength": 1
        },
        "composition": {
          "type": "string",
          "minLength": 1
        },
        "broll_style": {
          "type": "string",
          "minLength": 1
        },
        "motifs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "template_intent": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["short_video_maker", "remotion_direct", "money_printer_turbo", "editly", "ffmpeg_only"]
        },
        "template_id": {
          "type": "string",
          "minLength": 1
        },
        "style_preset": {
          "type": "string",
          "minLength": 1
        },
        "caption_position": {
          "type": "string",
          "enum": ["top", "center", "bottom"]
        },
        "composition_goal": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "beats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "visual_intent", "broll_search_terms"],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "visual_intent": {
            "type": "string",
            "minLength": 1
          },
          "broll_search_terms": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["external_file", "edge_tts", "elevenlabs", "azure", "none"]
        },
        "provider": {
          "type": "string"
        },
        "voice_name": {
          "type": "string"
        },
        "file_path": {
          "type": "string"
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filename": {
          "type": "string",
          "pattern": "^[^/\\\\]+\\.mp4$"
        }
      }
    },
    "publish": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
