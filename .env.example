# RAIZ Video Factory local configuration.
#
# Real render execution is disabled by default.
# Do not set RAIZ_ENABLE_REAL_RENDER=true until the real sender implementation is ready.
RAIZ_ENABLE_REAL_RENDER=false

# Orchestrator binds to localhost by default. Network binding requires both
# RAIZ_ALLOW_NETWORK_BIND=true and a non-empty RAIZ_API_TOKEN.
HOST=127.0.0.1
PORT=4000
RAIZ_ALLOW_NETWORK_BIND=false
RAIZ_API_TOKEN=

# HTTP mode assumes a separately running short-video-maker server in a future phase.
# Phase 15 only centralizes config; it does not call the server.
RAIZ_SHORT_VIDEO_MAKER_MODE=http
RAIZ_SHORT_VIDEO_MAKER_BASE_URL=http://localhost:3123
RAIZ_SHORT_VIDEO_MAKER_RENDER_PATH=/api/short-video
RAIZ_SHORT_VIDEO_MAKER_TIMEOUT_MS=120000

# vendor/ remains read-only. Do not install dependencies or mutate source inside vendor/.
RAIZ_SHORT_VIDEO_MAKER_VENDOR_PATH=vendor/short-video-maker

# Local job artifact root.
RAIZ_STORAGE_DIR=storage/jobs

# Optional: Pexels API key for fetching b-roll (free tier). Leave empty to skip
# Pexels entirely (local b-roll is the brand-first source). Used by
# scripts/fetch-pexels-broll.mjs. Put the real value only in .env (gitignored).
PEXELS_API_KEY=

# Voice-over (TTS) provider. "gemini" makes the render generate real Arabic
# voice-over via the Gemini API. When RAIZ_TTS_PROVIDER=gemini, GEMINI_API_KEY is
# REQUIRED — the render refuses to fall back to robotic/mock/silent audio.
RAIZ_TTS_PROVIDER=none
# Optional Gemini prebuilt voice name (e.g. Kore, Charon, Puck). Defaults to Kore.
RAIZ_TTS_VOICE=

# Gemini API key. Read ONLY from this gitignored .env (or the environment).
# Never commit it, never put it in samples, code, n8n workflows, or logs.
GEMINI_API_KEY=
