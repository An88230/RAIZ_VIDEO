# RAIZ Video Factory local configuration.
#
# Real render execution is disabled by default.
# Do not set RAIZ_ENABLE_REAL_RENDER=true until the real sender implementation is ready.
RAIZ_ENABLE_REAL_RENDER=false

# HTTP mode assumes a separately running short-video-maker server in a future phase.
# Phase 15 only centralizes config; it does not call the server.
RAIZ_SHORT_VIDEO_MAKER_MODE=http
RAIZ_SHORT_VIDEO_MAKER_BASE_URL=http://localhost:3123
RAIZ_SHORT_VIDEO_MAKER_RENDER_PATH=/api/short-video
RAIZ_SHORT_VIDEO_MAKER_TIMEOUT_MS=120000

# vendor/ remains read-only. Do not install dependencies or mutate source inside vendor/.
RAIZ_SHORT_VIDEO_MAKER_VENDOR_PATH=vendor/short-video-maker

# Local job artifact root.
RAIZ_STORAGE_DIR=storage/jobs
