{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nabil88.art/schemas/content_opportunity.schema.json",
  "title": "RAIZ Content Opportunity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "opportunity_id",
    "source_report_id",
    "mode_id",
    "title",
    "original_production_idea",
    "target_audience",
    "value_proposition",
    "production_plan",
    "affiliate_angles",
    "required_assets",
    "rights_plan",
    "safety_constraints",
    "scoring",
    "execution_policy",
    "created_at"
  ],
  "properties": {
    "opportunity_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "source_report_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "mode_id": {
      "type": "string",
      "enum": ["tech_discovery", "home_maintenance", "daily_life"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "original_production_idea": {
      "type": "string",
      "minLength": 1
    },
    "target_audience": {
      "type": "string",
      "minLength": 1
    },
    "value_proposition": {
      "type": "string",
      "minLength": 1
    },
    "production_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "estimated_duration_seconds", "scenes"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["short_video", "carousel_brief", "script_outline"]
        },
        "estimated_duration_seconds": {
          "type": "integer",
          "minimum": 5,
          "maximum": 180
        },
        "scenes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["scene_id", "purpose", "original_asset_needed"],
            "properties": {
              "scene_id": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9_-]+$"
              },
              "purpose": {
                "type": "string",
                "minLength": 1
              },
              "original_asset_needed": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "affiliate_angles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["angle", "product_category", "claim_safety"],
        "properties": {
          "angle": {
            "type": "string",
            "minLength": 1
          },
          "product_category": {
            "type": "string",
            "minLength": 1
          },
          "claim_safety": {
            "type": "string",
            "enum": ["safe_category_claim", "requires_review", "not_allowed"]
          }
        }
      }
    },
    "required_assets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rights_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pattern_only",
        "original_or_licensed_assets",
        "source_assets_reused",
        "attribution_notes"
      ],
      "properties": {
        "pattern_only": {
          "type": "boolean",
          "const": true
        },
        "original_or_licensed_assets": {
          "type": "boolean",
          "const": true
        },
        "source_assets_reused": {
          "type": "boolean",
          "const": false
        },
        "attribution_notes": {
          "type": "string"
        }
      }
    },
    "safety_constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scoring": {
      "$ref": "#/$defs/content_scores"
    },
    "execution_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "will_download_source_video",
        "will_repost_source_video",
        "will_remove_watermark",
        "will_scrape",
        "will_publish"
      ],
      "properties": {
        "will_download_source_video": {
          "type": "boolean",
          "const": false
        },
        "will_repost_source_video": {
          "type": "boolean",
          "const": false
        },
        "will_remove_watermark": {
          "type": "boolean",
          "const": false
        },
        "will_scrape": {
          "type": "boolean",
          "const": false
        },
        "will_publish": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "content_scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "curiosity_score",
        "usefulness_score",
        "originality_potential",
        "affiliate_potential",
        "production_difficulty",
        "rights_risk",
        "brand_fit",
        "remake_safety"
      ],
      "properties": {
        "curiosity_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "usefulness_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "originality_potential": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "affiliate_potential": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "production_difficulty": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "rights_risk": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "brand_fit": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "remake_safety": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        }
      }
    }
  }
}
